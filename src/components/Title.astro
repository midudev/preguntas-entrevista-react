---
interface Props {
  isHome?: boolean
}
const { isHome = false } = Astro.props

const classes = [
  'font-display max-w-2xl py-4 font-bold leading-[1.08] tracking-tight text-balance',
  isHome
    ? 'animate-fade-in-up animate-duration-700 animate-delay-200 text-5xl md:text-7xl text-slate-950 dark:text-white'
    : 'text-2xl md:text-4xl text-slate-900 dark:text-slate-100',
]
---

{
  isHome ? (
    <h1 class:list={classes}>Preguntas típicas de React.js</h1>
  ) : (
    <p class:list={classes} aria-hidden="false">
      <a
        href="/"
        class="text-inherit no-underline transition-colors hover:text-blue-700 dark:hover:text-blue-300"
      >
        Preguntas típicas de React.js
      </a>
    </p>
  )
}
