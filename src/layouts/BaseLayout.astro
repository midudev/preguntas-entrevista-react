---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import BuyBook from '../components/BuyBook.astro'
import Seo from '../components/Seo.astro'
import { DEFAULT_DESCRIPTION } from '../constants'

interface Props {
  title?: string
  description?: string
  canonical?: string
  type?: 'website' | 'article'
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonical = '/',
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props
---

<!doctype html>
<html lang="es-ES">
  <head>
    <meta charset="utf-8" />
    {/* Blocking theme bootstrap: must run before first paint to avoid light flash */}
    <script is:inline>
      ;(function () {
        var root = document.documentElement
        var theme
        try {
          theme = localStorage.getItem('theme')
        } catch (e) {}
        var dark =
          theme === 'dark' ||
          (theme !== 'light' &&
            window.matchMedia('(prefers-color-scheme: dark)').matches)
        if (dark) {
          root.classList.add('dark')
          root.style.colorScheme = 'dark'
          root.style.backgroundColor = '#0a0f1a'
        } else {
          root.classList.remove('dark')
          root.style.colorScheme = 'light'
          root.style.backgroundColor = '#fafbff'
        }
      })()
    </script>
    <style is:inline>
      html {
        background-color: #fafbff;
      }
      html.dark {
        background-color: #0a0f1a;
      }
      html,
      body {
        min-height: 100%;
      }
      body {
        background-color: inherit;
      }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fafbff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0f1a" media="(prefers-color-scheme: dark)" />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <slot name="head" />
  </head>
  <body class="app-shell overscroll-none bg-[#fafbff] text-slate-900 dark:bg-[#0a0f1a] dark:text-slate-100">
    <div class="relative flex min-h-screen flex-col overflow-x-clip">
      <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
      <Header />
      <main
        id="main-content"
        tabindex="-1"
        class="relative z-10 mx-auto block w-full max-w-6xl flex-1 px-5 pb-32 pt-3 md:px-8"
      >
        <slot />
      </main>
      <Footer />
      <BuyBook />
    </div>
    <div
      id="a11y-status"
      class="sr-only"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
    </div>
  </body>
</html>
