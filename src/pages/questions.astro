---
import BaseLayout from '../layouts/BaseLayout.astro'
import ListOfQuestions from '../components/ListOfQuestions.astro'
import { SITE_URL, SITE_NAME, absoluteUrl } from '../constants'
import { readIndex } from '../lib/posts'
import { stripMarkdown } from '../lib/markdown'

const questions = readIndex()
const title = 'Lista de preguntas de React para practicar'
const description =
  'Explora todas las preguntas de entrevista de React disponibles, marca las que ya has leído y repasa tu progreso.'

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: absoluteUrl('/questions'),
    inLanguage: 'es-ES',
    isPartOf: {
      '@type': 'WebSite',
      name: SITE_NAME,
      url: SITE_URL,
    },
    numberOfItems: questions.length,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: SITE_URL,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Lista de preguntas',
        item: absoluteUrl('/questions'),
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Todas las preguntas de React',
    numberOfItems: questions.length,
    itemListElement: questions.slice(0, 50).map((q, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: stripMarkdown(q.text),
      url: absoluteUrl(`/${q.id}`),
    })),
  },
]
---

<BaseLayout
  title={title}
  description={description}
  canonical="/questions"
  jsonLd={jsonLd}
>
  <nav aria-label="Migas de pan" class="mono-label pt-6">
    <ol class="flex flex-wrap items-center gap-1.5">
      <li>
        <a
          href="/"
          class="underline-offset-4 transition-colors hover:text-[var(--fg)] hover:underline"
        >
          Inicio
        </a>
      </li>
      <li aria-hidden="true" class="text-[var(--faint)]">/</li>
      <li>
        <span class="text-[var(--fg)]" aria-current="page">
          Lista de preguntas
        </span>
      </li>
    </ol>
  </nav>

  <section
    class="mt-8"
    aria-labelledby="questions-heading"
  >
    <h1
      id="questions-heading"
      class="font-display pb-4 text-4xl font-semibold text-[var(--fg)] md:text-5xl"
    >
      Lista de preguntas
    </h1>
    <p class="max-w-xl pb-6 text-base leading-relaxed text-[var(--muted)]">
      A continuación encontrarás las {questions.length} preguntas disponibles
      sobre React, agrupadas por nivel de dificultad.
    </p>

    <ul class="mono-label mb-8 flex list-none flex-wrap gap-5 p-0" aria-label="Leyenda de progreso">
      <li class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--level-easy)]" aria-hidden="true"></span>
        <span>Leídas</span>
      </li>
      <li class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--hairline-strong)]" aria-hidden="true"></span>
        <span>Por leer</span>
      </li>
    </ul>

    <ListOfQuestions showReadStatus />
  </section>
</BaseLayout>
