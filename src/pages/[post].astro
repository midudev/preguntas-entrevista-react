---
import BaseLayout from '../layouts/BaseLayout.astro'
import Pill from '../components/Pill.astro'
import ButtonRead from '../components/ButtonRead.astro'
import { Quiz } from '../components/Quiz'
import {
  listPosts,
  fetchPost,
  toMetaDescription,
} from '../lib/posts'
import { renderInlineMarkdown, stripMarkdown } from '../lib/markdown'
import { SITE_URL, SITE_NAME } from '../constants'
import '../styles/highlight.css'

export function getStaticPaths() {
  return listPosts()
}

const { post } = Astro.params
const postData = await fetchPost(post!)

if (!postData) {
  return Astro.redirect('/404')
}

const { content, level, title, prev, next } = postData
const description = toMetaDescription(content)
const canonical = `/${post}`
const plainTitle = stripMarkdown(title)
const titleHtml = renderInlineMarkdown(title)

const levelLabels: Record<number, string> = {
  0: 'Principiante',
  1: 'Intermedio',
  2: 'Experto',
  [-1]: 'Errores típicos',
}

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: plainTitle,
    description,
    inLanguage: 'es-ES',
    isPartOf: {
      '@type': 'WebSite',
      name: SITE_NAME,
      url: SITE_URL,
    },
    author: {
      '@type': 'Person',
      name: 'midudev',
      url: 'https://midu.dev',
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': new URL(canonical, SITE_URL).href,
    },
    articleSection: levelLabels[level] ?? 'React',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: SITE_URL,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: plainTitle,
        item: new URL(canonical, SITE_URL).href,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: plainTitle,
        acceptedAnswer: {
          '@type': 'Answer',
          text: description,
        },
      },
    ],
  },
]
---

<BaseLayout
  title={plainTitle}
  description={description}
  canonical={canonical}
  type="article"
  jsonLd={jsonLd}
>
  <header class="relative pt-10">
    <div class="flex flex-row gap-2 pb-4">
      <Pill level={level} />
      <ButtonRead title={title} />
    </div>
    <h1
      class="rich-text w-full pb-8 text-3xl font-bold leading-snug text-blue-900 md:text-4xl dark:text-blue-100"
      id="content"
      set:html={titleHtml}
    />
  </header>

  <article
    class="prose max-w-none pb-4 [&>hr]:hidden [&>h1]:text-3xl [&>h1]:font-bold [&>h1]:text-blue-900 [&>h1]:pb-8 [&>p]:pb-6 [&>p]:text-lg md:[&>p]:text-xl [&>p>strong]:bg-yellow-50 dark:[&>p>strong]:bg-yellow-950 [&_a]:text-blue-700 dark:[&_a]:text-blue-300 [&_a:hover]:underline [&>ul>li]:list-disc [&>ul]:text-lg md:[&>ul]:text-xl [&>ul]:text-blue-900 dark:[&>ul]:text-blue-200 [&>ul]:pb-4 [&>ul>li]:ml-5 [&>ul]:space-y-3 [&>pre]:overflow-x-auto [&>pre]:rounded-xl [&>pre]:text-white [&>pre]:mb-8 [&>pre]:p-8 [&>pre]:bg-slate-800"
    set:html={content}
  />

  <section class="mt-12 rounded-2xl border border-slate-200/80 bg-linear-to-b from-white to-slate-50/80 p-6 shadow-[0_1px_3px_rgb(0_0_0/4%),0_8px_24px_rgb(15_23_42/6%)] md:p-8 dark:border-slate-700/60 dark:from-slate-900 dark:to-slate-900/80 dark:shadow-[0_0_0_1px_rgb(255_255_255/6%),0_8px_24px_rgb(0_0_0/30%)]">
    <div class="mb-6 flex items-center gap-3">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-500/15 dark:text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/><path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/><path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/><path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/><path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/><path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/></svg>
      </span>
      <div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">
          Pon a prueba lo aprendido
        </h2>
        <p class="text-xs text-slate-500 dark:text-slate-400">
          Responde preguntas sobre este tema
        </p>
      </div>
    </div>
    <Quiz client:idle slug={post}>
      <div class="flex items-center justify-center gap-2 py-10 text-sm text-slate-500 dark:text-slate-400">
        Cargando preguntas…
      </div>
    </Quiz>
  </section>

  <footer class="py-12 clear-both text-center [&>a]:leading-snug [&>a]:hover:underline [&>a]:block [&>a]:my-2">
    {
      prev && (
        <a class="rich-text lg:float-left inline-flex items-center gap-1" href={`/${prev.id}#content`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12l14 0"/><path d="M5 12l6 6"/><path d="M5 12l6 -6"/></svg>
          <span set:html={renderInlineMarkdown(prev.text)} />
        </a>
      )
    }
    {
      next && (
        <a class="rich-text lg:float-right inline-flex items-center gap-1" href={`/${next.id}#content`}>
          <span set:html={renderInlineMarkdown(next.text)} />
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12l14 0"/><path d="M13 18l6 -6"/><path d="M13 6l6 6"/></svg>
        </a>
      )
    }
  </footer>
</BaseLayout>
