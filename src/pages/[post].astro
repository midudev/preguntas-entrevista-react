---
import BaseLayout from '../layouts/BaseLayout.astro'
import Pill from '../components/Pill.astro'
import ButtonRead from '../components/ButtonRead.astro'
import { Quiz } from '../components/Quiz'
import {
  listPosts,
  fetchPost,
  toMetaDescription,
  stripHtml,
} from '../lib/posts'
import { renderInlineMarkdown, stripMarkdown } from '../lib/markdown'
import { SITE_URL, SITE_NAME } from '../constants'
import '../styles/highlight.css'

export function getStaticPaths() {
  return listPosts()
}

const { post } = Astro.params
const postData = await fetchPost(post!)

if (!postData) {
  return Astro.redirect('/404')
}

const { content, level, title, prev, next } = postData
const description = toMetaDescription(content)
const canonical = `/${post}`
const plainTitle = stripMarkdown(title)
const titleHtml = renderInlineMarkdown(title)
const answerPlain = stripHtml(content)
const faqAnswer =
  answerPlain.length > 500
    ? `${answerPlain.slice(0, 497).trimEnd()}…`
    : answerPlain

const levelLabels: Record<number, string> = {
  0: 'Principiante',
  1: 'Intermedio',
  2: 'Experto',
  [-1]: 'Errores típicos',
}
const levelLabel = levelLabels[level] ?? 'React'
const pageUrl = new URL(canonical, SITE_URL).href

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: plainTitle,
    description,
    inLanguage: 'es-ES',
    image: `${SITE_URL}/og.jpg`,
    isPartOf: {
      '@type': 'WebSite',
      name: SITE_NAME,
      url: SITE_URL,
    },
    author: {
      '@type': 'Person',
      name: 'midudev',
      url: 'https://midu.dev',
      sameAs: ['https://twitter.com/midudev', 'https://github.com/midudev'],
    },
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
      logo: {
        '@type': 'ImageObject',
        url: `${SITE_URL}/og.jpg`,
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': pageUrl,
    },
    articleSection: levelLabel,
    keywords: ['React', 'entrevista', plainTitle, levelLabel],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: SITE_URL,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: plainTitle,
        item: pageUrl,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: plainTitle,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faqAnswer,
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: plainTitle,
    description,
    url: pageUrl,
    learningResourceType: 'pregunta de entrevista',
    inLanguage: 'es-ES',
    educationalLevel: levelLabel,
    teaches: 'React',
    isAccessibleForFree: true,
  },
]
---

<BaseLayout
  title={plainTitle}
  description={description}
  canonical={canonical}
  type="article"
  jsonLd={jsonLd}
>
  <nav aria-label="Migas de pan" class="pt-6 text-sm text-slate-500 dark:text-slate-400">
    <ol class="flex flex-wrap items-center gap-1.5">
      <li>
        <a
          href="/"
          class="font-medium text-slate-600 underline-offset-2 transition hover:text-blue-600 hover:underline dark:text-slate-300 dark:hover:text-blue-400"
        >
          Inicio
        </a>
      </li>
      <li aria-hidden="true" class="text-slate-400">/</li>
      <li>
        <span class="text-slate-800 dark:text-slate-200" aria-current="page">
          {plainTitle}
        </span>
      </li>
    </ol>
  </nav>

  <article aria-labelledby="content">
    <header class="relative pt-6">
      <div class="flex flex-row flex-wrap items-center gap-2 pb-4">
        <Pill level={level} as="p" />
        <ButtonRead title={title} />
      </div>
      <h1
        class="rich-text w-full pb-8 text-3xl font-bold leading-snug text-blue-900 md:text-4xl dark:text-blue-100"
        id="content"
        set:html={titleHtml}
      />
    </header>

    <div
      class="prose max-w-none pb-4 [&>hr]:hidden [&>h1]:text-3xl [&>h1]:font-bold [&>h1]:text-blue-900 [&>h1]:pb-8 [&>p]:pb-6 [&>p]:text-lg md:[&>p]:text-xl [&>p>strong]:bg-yellow-50 dark:[&>p>strong]:bg-yellow-950 [&_a]:text-blue-700 dark:[&_a]:text-blue-300 [&_a:hover]:underline [&>ul>li]:list-disc [&>ul]:text-lg md:[&>ul]:text-xl [&>ul]:text-blue-900 dark:[&>ul]:text-blue-200 [&>ul]:pb-4 [&>ul>li]:ml-5 [&>ul]:space-y-3 [&>pre]:overflow-x-auto [&>pre]:rounded-xl [&>pre]:text-white [&>pre]:mb-8 [&>pre]:p-8 [&>pre]:bg-slate-800"
      set:html={content}
    />
  </article>

  <section
    class="mt-12 rounded-2xl border border-slate-200/80 bg-linear-to-b from-white to-slate-50/80 p-6 shadow-[0_1px_3px_rgb(0_0_0/4%),0_8px_24px_rgb(15_23_42/6%)] md:p-8 dark:border-slate-700/60 dark:from-slate-900 dark:to-slate-900/80 dark:shadow-[0_0_0_1px_rgb(255_255_255/6%),0_8px_24px_rgb(0_0_0/30%)]"
    aria-labelledby="quiz-heading"
  >
    <div class="mb-6 flex items-center gap-3">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-500/15 dark:text-blue-400" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/><path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/><path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/><path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/><path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/><path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/></svg>
      </span>
      <div>
        <h2 id="quiz-heading" class="text-lg font-bold text-slate-900 dark:text-white">
          Pon a prueba lo aprendido
        </h2>
        <p class="text-xs text-slate-500 dark:text-slate-400" id="quiz-desc">
          Responde preguntas sobre este tema
        </p>
      </div>
    </div>
    <Quiz client:idle slug={post}>
      <div class="flex items-center justify-center gap-2 py-10 text-sm text-slate-500 dark:text-slate-400" role="status">
        Cargando preguntas…
      </div>
    </Quiz>
  </section>

  <nav
    class="clear-both py-12 text-center"
    aria-label="Navegación entre preguntas"
  >
    <div class="flex flex-col gap-4 lg:block">
      {
        prev && (
          <a
            class="rich-text inline-flex items-center justify-center gap-1 leading-snug hover:underline lg:float-left lg:my-2"
            href={`/${prev.id}#content`}
            rel="prev"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12l14 0"/><path d="M5 12l6 6"/><path d="M5 12l6 -6"/></svg>
            <span class="sr-only">Pregunta anterior: </span>
            <span set:html={renderInlineMarkdown(prev.text)} />
          </a>
        )
      }
      {
        next && (
          <a
            class="rich-text inline-flex items-center justify-center gap-1 leading-snug hover:underline lg:float-right lg:my-2"
            href={`/${next.id}#content`}
            rel="next"
          >
            <span class="sr-only">Pregunta siguiente: </span>
            <span set:html={renderInlineMarkdown(next.text)} />
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12l14 0"/><path d="M13 18l6 -6"/><path d="M13 6l6 6"/></svg>
          </a>
        )
      }
    </div>
  </nav>
</BaseLayout>
