---
import BaseLayout from '../layouts/BaseLayout.astro'
import Card from '../components/Card.astro'
import ListOfQuestions from '../components/ListOfQuestions.astro'
import {
  LEVELS,
  SITE_URL,
  SITE_NAME,
  DEFAULT_DESCRIPTION,
  OG_IMAGE_PATH,
  absoluteUrl,
} from '../constants'
import { readIndex } from '../lib/posts'

const title = 'Preguntas de React con respuestas y ejemplos'
const description =
  'Guía de React en español con preguntas de entrevista, conceptos clave y respuestas claras para practicar y preparar tus procesos técnicos.'

const featured = [
  {
    title: '¿Para qué sirve useEffect?',
    excerpt:
      'El hook useEffect se usa para ejecutar código cuando se renderiza el componente o cuando cambian las dependencias del efecto.',
    slug: '/que-hace-el-hook-use-effect#content',
    level: LEVELS.EASY,
  },
  {
    title: 'Cómo cancelar una petición fetch',
    excerpt:
      'Cuando hacemos una petición a una API, podemos cancelarla para evitar que se ejecute cuando el componente se desmonte usando AbortController como hacemos en este ejemplo',
    slug: '/como-puedes-cancelar-una-peticion-a-una-api-en-use-effect-correctamente#content',
    level: LEVELS.MEDIUM,
  },
  {
    title: '¿Qué es la hidratación?',
    excerpt:
      'La hidratación convierte el HTML estático que devuelve el servidor en HTML interactivo que puede responder a eventos del usuario en el cliente.',
    slug: '/que-es-la-hidratacion-hydration-en-react#content',
    level: LEVELS.MEDIUM,
  },
  {
    title: '¿Qué hace el hook useId?',
    excerpt:
      'El hook useId nos permite crear identificadores únicos, muy útiles para formularios y otros casos.',
    slug: '/que-hace-el-hook-use-id#content',
    level: LEVELS.EASY,
  },
  {
    title: 'Es React una biblioteca o framework',
    excerpt:
      'Existe una fina línea hoy en día entre qué es una biblioteca o un framework. Oficialmente, React se autodenomina como biblioteca.',
    slug: '/es-react-una-biblioteca-o-un-framework-por-que#content',
    level: LEVELS.HARD,
  },
  {
    title: '¿Qué son las Render Props?',
    excerpt:
      'Las render props son un patrón de diseño de React que nos permite inyectar información en los elementos que renderizamos.',
    slug: '/que-son-las-render-props#content',
    level: LEVELS.HARD,
  },
]

const allQuestions = readIndex()
const totalQuestions = allQuestions.length
const byLevel = {
  beginner: allQuestions.filter(q => q.level === LEVELS.EASY).length,
  intermediate: allQuestions.filter(q => q.level === LEVELS.MEDIUM).length,
  expert: allQuestions.filter(q => q.level === LEVELS.HARD).length,
  errors: allQuestions.filter(q => q.level === LEVELS.ERRORS).length,
}

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
    description: DEFAULT_DESCRIPTION,
    inLanguage: 'es-ES',
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
      logo: {
        '@type': 'ImageObject',
        url: absoluteUrl(OG_IMAGE_PATH),
      },
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${SITE_URL}/?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL,
    logo: absoluteUrl(OG_IMAGE_PATH),
    sameAs: [
      'https://github.com/midudev/preguntas-entrevista-react',
      'https://twitter.com/midudev',
      'https://midu.dev',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Preguntas de entrevista de React más buscadas',
    numberOfItems: featured.length,
    itemListElement: featured.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: new URL(item.slug.split('#')[0], SITE_URL).href,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: SITE_URL,
    inLanguage: 'es-ES',
    isPartOf: {
      '@type': 'WebSite',
      name: SITE_NAME,
      url: SITE_URL,
    },
    about: {
      '@type': 'Thing',
      name: 'React',
    },
    numberOfItems: totalQuestions,
  },
]
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  jsonLd={jsonLd}
>
  <section class="home-intro" aria-labelledby="home-intro-heading">
    <div class="home-intro-copy">
      <p class="home-intro-kicker animate-fade-in-up animate-duration-500 animate-delay-500">
        Guía para entrevistas técnicas
      </p>
      <h2
        id="home-intro-heading"
        class="home-intro-title animate-blurred-fade-in animate-duration-700 animate-delay-700"
      >
        Preguntas reales.
        <span class="home-intro-title-accent">Respuestas con contexto.</span>
      </h2>
      <p class="home-intro-lead animate-fade-in-up animate-duration-500 animate-delay-800">
        Los temas que más se repiten en procesos de selección, explicados en
        español y con ejemplos. Practica con criterio, no con definiciones
        memorizadas. Más de {totalQuestions} preguntas.
      </p>
      <div class="home-intro-actions animate-fade-in-up animate-duration-500 animate-delay-900">
        <a href="#featured-heading" class="home-intro-btn home-intro-btn-primary">
          Ver las más buscadas
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M19 12l-7 7l-7 -7"/></svg>
        </a>
        <a href="#archive-heading" class="home-intro-btn home-intro-btn-ghost">
          Explorar todo el archivo
        </a>
      </div>
    </div>

    <ul class="home-intro-levels" aria-label="Preguntas por nivel">
      <li class="animate-fade-in-up animate-duration-500 animate-delay-900">
        <a href="/questions#category-beginner" class="home-level-chip home-level-chip-easy">
          <span class="home-level-chip-count tabular-nums">{byLevel.beginner}</span>
          <span class="home-level-chip-name">Principiante</span>
        </a>
      </li>
      <li class="animate-fade-in-up animate-duration-500 animate-delay-1000">
        <a href="/questions#category-intermediate" class="home-level-chip home-level-chip-medium">
          <span class="home-level-chip-count tabular-nums">{byLevel.intermediate}</span>
          <span class="home-level-chip-name">Intermedio</span>
        </a>
      </li>
      <li class="animate-fade-in-up animate-duration-500 animate-delay-1100">
        <a href="/questions#category-expert" class="home-level-chip home-level-chip-hard">
          <span class="home-level-chip-count tabular-nums">{byLevel.expert}</span>
          <span class="home-level-chip-name">Experto</span>
        </a>
      </li>
      <li class="animate-fade-in-up animate-duration-500 animate-delay-1200">
        <a href="/questions#category-errors" class="home-level-chip home-level-chip-errors">
          <span class="home-level-chip-count tabular-nums">{byLevel.errors}</span>
          <span class="home-level-chip-name">Errores</span>
        </a>
      </li>
    </ul>
  </section>

  <section class="mt-14 md:mt-16" aria-labelledby="featured-heading">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3 animate-fade-in-up animate-duration-500 animate-delay-1000">
      <h2
        id="featured-heading"
        class="font-display text-2xl font-bold text-slate-900 md:text-3xl dark:text-white"
      >
        Las preguntas más buscadas
      </h2>
      <a
        href="/questions"
        class="text-sm font-semibold text-blue-600 transition hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300"
      >
        Ver todas →
      </a>
    </div>
    <ul class="grid list-none grid-cols-1 gap-5 p-0 sm:gap-6 sm:grid-cols-2 lg:gap-7 lg:grid-cols-3 [&>*]:min-w-0">
      {
        featured.map((item, i) => (
          <li
            class:list={[
              'min-w-0 animate-fade-in-up animate-duration-500',
              i === 0 && 'animate-delay-1100',
              i === 1 && 'animate-delay-1200',
              i === 2 && 'animate-delay-1300',
              i === 3 && 'animate-delay-1400',
              i === 4 && 'animate-delay-1500',
              i === 5 && 'animate-delay-1600',
            ]}
          >
            <Card
              title={item.title}
              excerpt={item.excerpt}
              slug={item.slug}
              level={item.level}
            />
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="hero-panel mt-16 animate-fade-in animate-duration-700 px-6 py-10 md:px-12 md:py-12"
    aria-labelledby="archive-heading"
  >
    <h2
      id="archive-heading"
      class="font-display pb-3 text-2xl font-bold text-slate-900 md:text-3xl dark:text-white"
    >
      Todo el archivo de preguntas sobre React
    </h2>
    <p class="pb-6 text-slate-600 dark:text-slate-300">
      Explora todas las preguntas disponibles y marca lo que ya has repasado
      para llevar un progreso real.
    </p>
    <ListOfQuestions showReadStatus />
  </section>
</BaseLayout>
